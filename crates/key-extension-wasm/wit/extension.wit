package key:extension-runtime@0.1.0;

/// Minimal transport world for the first extension runtime adapter. Event and
/// update bytes use the versioned `ExtensionUpdate` JSON representation from
/// key-extension-api (an optional immutable UI state snapshot plus effects).
/// Host capabilities are deliberately absent: a host must explicitly link a
/// separately permissioned WIT interface before a component can import it.
world extension {
    export activate: func();
    export handle-event: func(event-json: list<u8>) -> list<u8>;
    export deactivate: func();
}
